# Copy this file to .env.local (gitignored) and fill in the values.
# Both dev (`npm run dev`) and the packaged .app read from these names.

# Semantic Scholar Graph API key (optional but strongly recommended).
# Without a key S2 falls back to the anonymous rate limit (≈1 req per 5 min)
# which will rate-limit the refresh pipeline to uselessness.
# Get one (free, 1 req/sec tier) at:
#   https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=
